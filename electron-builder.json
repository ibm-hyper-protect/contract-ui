{
  "appId": "com.ibm.cc.contract-ui",
  "productName": "IBM Confidential Computing Contract UI",
  "productNameShort": "IBM-CC-Contract-UI",
  "asar": true,
  "compression": "normal",
  "buildDependenciesFromSource": false,
  "npmRebuild": false,
  "asarUnpack": [
    "node_modules/sharp/**/*"
  ],
  "artifactName": "${productNameShort}-${version}-${os}-${arch}.${ext}",
  "directories": {
    "output": "dist-electron",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "main/**/*",
    "package.json"
  ],
  "extraMetadata": {
    "main": "main/index.js"
  },
  "mac": {
    "category": "public.app-category.developer-tools",
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "zip",
        "arch": ["x64", "arm64"]
      }
    ],
    "hardenedRuntime": false,
    "gatekeeperAssess": false
  },
  "win": {
    "target": [
      {
        "target": "portable",
        "arch": ["x64", "arm64"]
      }
    ]
  },
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "deb",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "rpm",
        "arch": ["x64", "arm64"]
      }
    ],
    "icon": "icon.png",
    "category": "Development"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  },
  "dmg": {
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ]
  }
}
