{
  "name": "cc-contract-ui",
  "version": "1.2.0",
  "description": "IBM CC Contract UI - A Persona Contract Generator for IBM Confidential Computing",
  "main": "main/index.js",
  "scripts": {
    "start": "vite",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "prebuild": "npm run clean",
    "clean": "rm -rf dist dist-electron",
    "package": "npm run build && electron-builder --config electron-builder.json",
    "package:mac": "npm run build && electron-builder --config electron-builder.json --mac",
    "package:win": "npm run build && electron-builder --config electron-builder.json --win",
    "package:linux": "npm run build && electron-builder --config electron-builder.json --linux"
  },
  "keywords": [
    "ibm-hyper-protect",
    "ibm-confidential-computing",
    "hyper-protect",
    "confidential-computing",
    "contract-builder",
    "ccrt",
    "ccrv",
    "ccco"
  ],
  "author": {
    "name": "IBM Hyper Protect",
    "email": "zaas.client.acceleration@ibm.com"
  },
  "homepage": "https://github.com/ibm-hyper-protect/contract-ui",
  "repository": {
    "type": "git",
    "url": "https://github.com/ibm-hyper-protect/contract-ui"
  },
  "bugs": {
    "url": "https://github.com/ibm-hyper-protect/contract-ui/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=25.9.0",
    "npm": ">=11.12.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.10.2",
    "electron-builder": "^26.15.3",
    "vite": "^8.0.3",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@carbon/charts": "^1.27.3",
    "@carbon/charts-react": "^1.27.3",
    "@carbon/icons-react": "^11.77.1",
    "@carbon/react": "^1.104.1",
    "axios": "^1.7.9",
    "d3": "^7.9.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.1.3",
    "sass": "^1.99.0",
    "zustand": "^5.0.2"
  }
}
